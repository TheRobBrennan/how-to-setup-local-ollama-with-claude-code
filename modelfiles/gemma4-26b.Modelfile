FROM gemma4:26b-a4b-it-q8_0

PARAMETER temperature 1.0
PARAMETER top_k 40

# Flash attention and KV cache quantization are Ollama server-level settings.
# They cannot be set in a Modelfile — set these environment variables before
# starting (or restarting) the Ollama server:
#
#   OLLAMA_FLASH_ATTENTION=1
#   OLLAMA_KV_CACHE_TYPE=q8_0
#
# On macOS with Ollama running as a background app, set them in your shell
# profile (~/.zshrc) and restart Ollama:
#
#   echo 'export OLLAMA_FLASH_ATTENTION=1' >> ~/.zshrc
#   echo 'export OLLAMA_KV_CACHE_TYPE=q8_0' >> ~/.zshrc
#   source ~/.zshrc
#   # Then restart Ollama from the menu bar or: killall ollama && ollama serve
